# GigFlow Smart Leads Dashboard — environment reference
# Copy service-specific files:
#   backend/.env.example  → backend/.env
#   frontend/.env.example → frontend/.env# This file contains placeholders only. Do not commit real secrets.
# ─── Backend (backend/.env) ───
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/gigflow-leads
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
ALLOW_ADMIN_REGISTRATION=false
# GOOGLE_CLIENT_ID=optional-for-google-sign-in

# ─── Frontend (frontend/.env) ───
VITE_API_URL=http://localhost:5000/api
# VITE_GOOGLE_CLIENT_ID=optional-for-google-sign-in
