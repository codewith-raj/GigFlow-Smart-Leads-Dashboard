# =============================================================================
# GIGFLOW SMART LEADS — BACKEND ENV TEMPLATE
# Copy to .env for local dev, or paste values into your host (Render/Railway)
# =============================================================================

PORT=5000
NODE_ENV=production
MONGODB_URI=mongodb+srv://<DB_USER>:<DB_PASSWORD>@<CLUSTER>.mongodb.net/gigflow-smart-leads?retryWrites=true&w=majority
JWT_SECRET=<GENERATE_A_STRONG_RANDOM_SECRET_32_CHARS_MIN>
JWT_EXPIRES_IN=7d
ALLOW_ADMIN_REGISTRATION=false
FRONTEND_URL=https://<YOUR-FRONTEND>.vercel.app
GOOGLE_CLIENT_ID=<YOUR_GOOGLE_CLIENT_ID>.apps.googleusercontent.com
